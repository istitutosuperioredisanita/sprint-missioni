<settings xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://maven.apache.org/SETTINGS/1.2.0"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.2.0 http://maven.apache.org/xsd/settings-1.2.0.xsd">
    <servers>
        <server>
            <id>sonatype</id>
            <username>${sonatype.login}</username>
            <password>${sonatype.pwd}</password>
        </server>
        <server>
            <id>buildandtest</id>
            <username>${nexus.login}</username>
            <password>${nexus.pwd}</password>
        </server>
        <!-- Aggiungo questa configurazione per GitHub -->
        <server>
            <id>github</id>
            <username>${GITHUB_USERNAME}</username>
            <password>${GITHUB_TOKEN}</password>
        </server>
    </servers>
    <mirrors>
        <mirror>
            <id>maven-default-http</id>
            <mirrorOf>external:http:*</mirrorOf>
            <name>Pseudo repository to mirror external repositories initially using HTTP.</name>
            <url>http://maven.si.cnr.it/content/groups/public/</url>
            <blocked>false</blocked>
        </mirror>
    </mirrors>
    <profiles>
        <profile>
            <id>sonar</id>
            <activation>
                <activeByDefault>true</activeByDefault>
            </activation>
            <properties>
                <sonar.host.url>${sonar.host.url}</sonar.host.url>
            </properties>
        </profile>
        <profile>
            <id>nexus</id>
            <repositories>
                <repository>
                    <id>public</id>
                    <name>public</name>
                    <url>${nexus.url}/content/groups/public</url>
                </repository>
            </repositories>
            <properties>
                <nexus.url>${nexus.url}</nexus.url>
            </properties>
        </profile>
        <!-- Aggiungo questo profilo per GitHub -->
        <profile>
            <id>github</id>
            <repositories>
                <repository>
                    <id>central</id>
                    <url>https://repo1.maven.org/maven2</url>
                </repository>
                <repository>
                    <id>github</id>
                    <url>https://maven.pkg.github.com/istitutosuperioredisanita/sprint-missioni</url>
                    <snapshots>
                        <enabled>true</enabled>
                    </snapshots>
                </repository>
            </repositories>
        </profile>
    </profiles>
    <activeProfiles>
        <activeProfile>nexus</activeProfile>
        <!-- Attivo il profilo GitHub -->
        <activeProfile>github</activeProfile>
    </activeProfiles>
</settings>